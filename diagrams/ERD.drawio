        <mxCell id="NStmnrzztc_lttVf1uG3-548" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Note&lt;/h1&gt;&lt;div&gt;&lt;div&gt;Every lesson in a course has an Order (0, 1, 2, 3...).&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;* If a student finishes Lesson 0 and Lesson 2, the bitset is 10100....&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;* Why it’s efficient: Storing 100 bits (for a 100-lesson course) takes only 13 bytes. Storing 100 rows in a&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;relational table takes ~4-8 KB.&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;* Querying: To check if a student is 100% finished, you just compare the bitmask to a string of all 1s&lt;/div&gt;&lt;/div&gt;&lt;div&gt;* you can use bracket to group videos into modules if necessary&lt;/div&gt;" vertex="1">
          <mxGeometry height="287.5" width="240" x="1530" y="-845" as="geometry" />
        </mxCell>
        <mxCell id="NStmnrzztc_lttVf1uG3-552" edge="1" parent="1" source="NStmnrzztc_lttVf1uG3-461" style="edgeStyle=entityRelationEdgeStyle;fontSize=12;html=1;endArrow=ERzeroToMany;startArrow=ERmandOne;rounded=0;" target="NStmnrzztc_lttVf1uG3-524" value="">
          <mxGeometry height="100" relative="1" width="100" as="geometry">
            <Array as="points">
              <mxPoint x="1230.5" y="-655" />
            </Array>
            <mxPoint x="1040.5" y="-665" as="sourcePoint" />
            <mxPoint x="1140.5" y="-765" as="targetPoint" />
          </mxGeometry>
        </mxCell>
